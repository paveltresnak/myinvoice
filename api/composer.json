{
    "name": "myinvoice/api",
    "description": "MyInvoice.cz — fakturační systém (PHP backend)",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.5",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "chillerlan/php-qrcode": "^6.0",
        "enshrined/svg-sanitize": "^0.22",
        "guzzlehttp/guzzle": "^7.9",
        "monolog/monolog": "^3.7",
        "mpdf/mpdf": "^8.2",
        "php-di/php-di": "^7.0",
        "predis/predis": "^3.4",
        "respect/validation": "^3.1",
        "rikudou/czqrpayment": "^5.3",
        "rikudou/iban": "^1.3",
        "slim/psr7": "^1.6",
        "slim/slim": "^4.13",
        "smalot/pdfparser": "^2.12",
        "smhg/sepa-qr-data": "^3.0",
        "symfony/mailer": "^8.0",
        "symfony/mime": "^8.0",
        "symfony/uid": "^8.0",
        "twig/twig": "^3.10"
    },
    "require-dev": {
        "dg/bypass-finals": "^1.9",
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "MyInvoice\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MyInvoice\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@php bin/cleanup-mpdf-fonts.php"
        ],
        "post-update-cmd": [
            "@php bin/cleanup-mpdf-fonts.php"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
