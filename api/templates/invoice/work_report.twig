{# MyInvoice.cz — PDF samostatného výkazu víceprací (Vykaz-XYZ.pdf pro schvalovací email) #}
{# Variables: invoice, supplier, work_report, locale, date_format, decimal_sep, thousand_sep, css, logo_path #}
<!doctype html>
<html lang="{{ locale|default('cs') }}">
<head>
<meta charset="utf-8">
<title></title>
<style>{{ css|raw }}</style>
</head>
<body>

{% set wr_has_dates = (work_report.items|filter(it => it.work_date)|length) > 0 %}

<table class="head">
  <tr>
    {% if logo_show_name and logo_path and logo_path is not empty %}
      {# Logo + název firmy — dvě sousední buňky (stejně jako faktura, kvůli mPDF). #}
      <td class="logo-img-cell"><img src="{{ logo_path }}" alt="logo"></td>
      <td class="logo-name">{{ supplier.display_name|default(supplier.company_name) }}</td>
    {% else %}
      <td class="logo">
        {% if logo_path and logo_path is not empty %}
          <img src="{{ logo_path }}" alt="logo" style="max-width: 72mm; max-height: 20mm;">
        {% else %}
          <div class="brand-name">{{ supplier.company_name }}</div>
        {% endif %}
      </td>
    {% endif %}
    <td class="meta">
      <div class="doc-type">{{ t('Výkaz víceprací — ke schválení', 'Work report — for approval') }}</div>
      {% if invoice.varsymbol %}
        <div class="varsymbol-big">{{ invoice.varsymbol }}</div>
      {% else %}
        <div class="varsymbol-big">DRAFT-{{ invoice.id }}</div>
      {% endif %}
    </td>
  </tr>
</table>

<div style="margin-bottom:5mm;">
  <div style="font-size:11pt;font-weight:bold;color:#3B2D83;margin-bottom:1mm;">{{ work_report.title }}</div>
  <div style="font-size:9pt;color:#5A5470;">
    {% if invoice.client_company_name %}
      {{ t('Pro', 'For') }}: <strong>{{ invoice.client_company_name }}</strong>
    {% endif %}
    {% if invoice.project_name %} · {{ t('Zakázka', 'Project') }}: {{ invoice.project_name }}{% endif %}
    {% if invoice.project_number %} · {{ t('Vaše číslo', 'Your order no.') }}: {{ invoice.project_number }}{% endif %}
    {% if invoice.contract_number %} · {{ t('Vaše smlouva', 'Your contract') }}: {{ invoice.contract_number }}{% endif %}
  </div>
</div>

<table class="items">
  <thead>
    <tr>
      <th style="width:{% if wr_has_dates %}43%{% else %}55%{% endif %}">{{ t('Popis', 'Description') }}</th>
      {% if wr_has_dates %}<th class="nowrap" style="width:12%">{{ t('Datum', 'Date') }}</th>{% endif %}
      <th class="num nowrap" style="width:13%">{{ t('Hodiny', 'Hours') }}</th>
      <th class="num nowrap" style="width:14%">{{ t('Sazba', 'Rate') }}</th>
      <th class="num nowrap" style="width:18%">{{ t('Celkem', 'Total') }}</th>
    </tr>
  </thead>
  <tbody>
    {% for it in work_report.items %}
    <tr>
      <td>{{ it.description|nl2br }}</td>
      {% if wr_has_dates %}<td class="nowrap">{% if it.work_date %}{{ it.work_date|date(date_format) }}{% endif %}</td>{% endif %}
      <td class="num nowrap">{{ it.hours|number_format(2, decimal_sep, thousand_sep) }}</td>
      <td class="num nowrap">{{ it.rate|number_format(2, decimal_sep, thousand_sep) }} {{ invoice.currency }}</td>
      <td class="num nowrap">{{ it.total_amount|number_format(2, decimal_sep, thousand_sep) }} {{ invoice.currency }}</td>
    </tr>
    {% endfor %}
    <tr style="background:#F4F2F8;font-weight:bold;">
      <td style="text-align:right;" {% if wr_has_dates %}colspan="2"{% endif %}>{{ t('Celkem', 'Total') }}</td>
      <td class="num nowrap">{{ work_report.total_hours|number_format(2, decimal_sep, thousand_sep) }} h</td>
      <td></td>
      <td class="num nowrap">{{ work_report.total_amount|number_format(2, decimal_sep, thousand_sep) }} {{ invoice.currency }}</td>
    </tr>
  </tbody>
</table>

<div class="footer">
  {{ supplier.company_name }}{% if supplier.web %} · {{ supplier.web }}{% endif %}{% if supplier.email %} · {{ supplier.email }}{% endif %}
</div>

</body>
</html>
